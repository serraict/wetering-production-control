# Database Connection
# Format for Dremio Flight SQL connection string (as used in Superset):
VINEAPP_DB_CONNECTION=dremio+flight://user:pass@localhost:32010/dremio?UseEncryption=false

# Optional Settings
# Set to 'true' to enable SQL query logging
VINEAPP_SQL_ECHO=false

# Fibery knowledge base
VINEAPP_FIBERY_URL="https://serra.fibery.io"
VINEAPP_FIBERY_SPACE="Public"

# OpTech API
VINEAPP_OPTECH_API_URL="http://optech.localhost"

# dremio_simple_query script:
SIMPLE_QUERY_CONNECTION=grpc://user:pass@localhost:32010

# For QR code generation
# Uses the new URL scheme: https://pv.[environment].serraict.me
QR_CODE_BASE_URL="https://pc.${VINE_ENVIRONMENT}.serraict.me"

# Label dimensions
LABEL_WIDTH="151mm"
LABEL_HEIGHT="101mm"

# Firebird Database Configuration (for production deployment)
# These defaults work for local Docker development
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=/firebird/data/production.fdb
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# NiceGUI Configuration
# The API uses this port to construct the base URL
NICEGUI_PORT=8080
NICEGUI_STORAGE_SECRET=production-control-default-secret

# OPC UA — ontstapelmachine (destacker) integration
# PLC and Leuze scanner endpoints; IPs/ports to be set per environment.
VINEAPP_OPCUA_PLC_URL=opc.tcp://plc.example.local:4840
VINEAPP_OPCUA_PLC_USER=
VINEAPP_OPCUA_PLC_PASSWORD=
VINEAPP_OPCUA_LEUZE_URL=opc.tcp://leuze.example.local:4840
# Client certificate (DER) and private key (PEM) — mount these into the container.
VINEAPP_OPCUA_CLIENT_CERT=certs/client_cert.der
VINEAPP_OPCUA_CLIENT_KEY=certs/client_cert_key.pem
