# Database Connection
# Format for Dremio Flight SQL connection string (as used in Superset):
VINEAPP_DB_CONNECTION=dremio+flight://user:pass@localhost:32010/dremio?UseEncryption=false

# Optional Settings
# Set to 'true' to enable SQL query logging
VINEAPP_SQL_ECHO=false

# Fibery knowledge base
VINEAPP_FIBERY_URL="https://serra.fibery.io"
VINEAPP_FIBERY_SPACE="Public"

# OpTech API
VINEAPP_OPTECH_API_URL="http://optech.localhost"

# dremio_simple_query script:
SIMPLE_QUERY_CONNECTION=grpc://user:pass@localhost:32010

# For QR code generation
# Uses the new URL scheme: https://pv.[environment].serraict.me
QR_CODE_BASE_URL="https://pc.${VINE_ENVIRONMENT}.serraict.me"

# Label dimensions
LABEL_WIDTH="151mm"
LABEL_HEIGHT="101mm"

# Firebird Database Configuration (for production deployment)
# These defaults work for local Docker development
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=/firebird/data/production.fdb
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# NiceGUI Configuration
# The API uses this port to construct the base URL
NICEGUI_PORT=8080
NICEGUI_STORAGE_SECRET=production-control-default-secret

# OPC UA — ontstapelmachine (destacker) integration
# PLC and Leuze scanner endpoints; IPs/ports to be set per environment.
VINEAPP_OPCUA_PLC_URL=opc.tcp://plc.example.local:4840
VINEAPP_OPCUA_PLC_USER=
VINEAPP_OPCUA_PLC_PASSWORD=
VINEAPP_OPCUA_LEUZE_URL=opc.tcp://leuze.example.local:4840
VINEAPP_OPCUA_LEUZE_USER=
VINEAPP_OPCUA_LEUZE_PASSWORD=
# Client certificate (DER) and private key (PEM) — mount these into the container.
VINEAPP_OPCUA_CLIENT_CERT=certs/client_cert.der
VINEAPP_OPCUA_CLIENT_KEY=certs/client_cert_key.pem
# Uncomment for local development against the test server (anonymous + NoSecurity).
# Skips user/password and cert/key entirely; only the *_URL vars are needed.
#VINEAPP_OPCUA_SECURITY=none

# Zulip — per-lot conversation backend
# Bot account credentials from Settings → Personal → Bots in your Zulip org.
# When unset, the communication card renders a "Zulip onbereikbaar" notice.
ZULIP_SITE=https://zulip.${VINE_ENVIRONMENT}.serraict.me
ZULIP_BOT_EMAIL=serrabot-bot@zulip.${VINE_ENVIRONMENT}.serraict.me
ZULIP_BOT_API_KEY=
# Stream messages are posted into; topic is the lot id.
ZULIP_STREAM=teelt
# Optional tuning.
ZULIP_TIMEOUT=5
ZULIP_HISTORY_LIMIT=50

# Zulip insights bot — see docs/adr/0002-zulip-insights-bot.md
# Required: an OpenRouter key (https://openrouter.ai). The bot uses
# the same VINEAPP_DB_CONNECTION (read-only) above for Dremio.
OPENROUTER_API_KEY=
# Pick any model OpenRouter exposes. Defaults to anthropic/claude-sonnet-4.6.
# Curated alternatives (see src/production_control/bot/llm.py::MODEL_EXAMPLES):
#   anthropic/claude-sonnet-4.6     # default; balanced, reliable tools
#   anthropic/claude-opus-4-7       # top reasoning; slower/costlier
#   anthropic/claude-haiku-4-5      # fast and cheap Claude
#   google/gemini-2.5-pro           # strong reasoning + tools
#   google/gemini-2.5-flash         # fast/cheap; lighter tool reliability
#   mistralai/mistral-large-2411    # Mistral flagship
#   mistralai/codestral-2501        # code/SQL-leaning
#   deepseek/deepseek-r1            # reasoning-focused
#   deepseek/deepseek-chat          # cheap general chat
BOT_MODEL=anthropic/claude-sonnet-4.6
# Optional: override the audit log path (default: var/bot-audit.jsonl).
# BOT_AUDIT_PATH=var/bot-audit.jsonl
# Shared token for Zulip outgoing-webhook verification. This is NOT
# the bot's API key shown in the bot card — it's a separate value
# Zulip stores on the bot's outgoing-webhook Service row. Grab it via
# the "Download config of all active outgoing webhook bots" link on
# Settings → Personal/Org → Bots; it appears in the downloaded
# `.zuliprc` as `token = ...`. Without this set, POST /zulip refuses
# all requests with 401.
ZULIP_OUTGOING_WEBHOOK_TOKEN=
